# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL (requerido para OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic (Claude AI para el chat)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Meta Ads (NUNCA exponer al frontend — solo backend)
# Obtener en: https://developers.facebook.com/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
# Obtener en: https://developers.facebook.com/tools/explorer/
META_ACCESS_TOKEN=your_meta_access_token
# Formato: act_XXXXXXXXX
META_AD_ACCOUNT_ID=act_your_account_id

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Site URL (required for OAuth redirects) ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── AI Layer ───
# OpenRouter es el proveedor activo en beta (free tier).
# Cuando pases a producción, agrega ANTHROPIC_API_KEY y actualiza lib/ai/roles.ts.
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Anthropic — opcional en beta, requerido en producción (Analyst/CreativeGen/Critic).
# Crea una en https://console.anthropic.com ($5 de crédito gratis al registrarte).
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Meta Ads (server-only, NUNCA exponer al frontend) ───
# El token se guarda por usuario en la tabla meta_connections.
# Las variables de abajo son solo para dev/testing con un token global.
# META_ACCESS_TOKEN=your_meta_access_token
# META_AD_ACCOUNT_ID=act_your_account_id
